{
  "identifier": "default",
  "description": "Main capability for MysterBox desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:read-all",
    "fs:write-all",
    "fs:scope-home",
    "fs:scope-desktop",
    "fs:scope-download",
    "fs:scope-document"
  ]
}
