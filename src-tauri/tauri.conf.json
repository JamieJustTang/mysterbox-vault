{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MysterBox",
  "version": "2.0.0",
  "identifier": "com.jamietang.mysterbox",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:14131",
    "frontendDist": "../dist"
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [],
    "targets": ["dmg"]
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "MysterBox",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ]
  },
  "plugins": {
    "dialog": {
      "open": true,
      "save": true
    },
    "fs": {
      "all": true,
      "scope": ["**"]
    }
  }
}
