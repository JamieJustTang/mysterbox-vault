{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MysterBox",
  "version": "1.0.0",
  "identifier": "com.jamietang.mysterbox",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "resources": [],
    "targets": ["dmg"]
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "MysterBox",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ]
  }
}
